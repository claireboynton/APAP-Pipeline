import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score

# load data
df = pd.read_csv("all_watch_data_4hz.csv")

# drop accelerometer + person id
df = df.drop(columns=["x", "y", "z", "person_id"])

# OPTIONAL: turn pain_scale into binary (pain vs no pain)
df["pain_label"] = df["pain_scale"].apply(lambda x: 0 if x == 0 else 1)

# features + target
X = df[["bvp", "eda", "temperature"]]
y = df["pain_label"]

# split
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)

# model
model = RandomForestClassifier()
model.fit(X_train, y_train)

# predict
preds = model.predict(X_test)

# result
print("Accuracy:", accuracy_score(y_test, preds))
